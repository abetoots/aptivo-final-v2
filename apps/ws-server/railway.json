{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @aptivo/ws-server build",
    "watchPatterns": [
      "apps/ws-server/**",
      "packages/types/**",
      "pnpm-lock.yaml"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @aptivo/ws-server start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
}
