# =============================================================================
# Aptivo — Environment Variables
# Copy to .env and fill in values for local development
# =============================================================================

# Application
NODE_ENV=development
SERVICE_NAME=aptivo-web
SERVICE_VERSION=0.0.1
LOG_LEVEL=debug

# Database (PostgreSQL 16 via docker-compose)
DATABASE_URL=postgresql://aptivo:aptivo_dev@localhost:5432/aptivo_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# Redis (via docker-compose)
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# Authentication (Supabase)
AUTH_ISSUER=https://your-project.supabase.co
AUTH_CLIENT_ID=your-client-id
AUTH_CLIENT_SECRET=your-client-secret
AUTH_SECRET=change-me-to-a-32-character-or-longer-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=AIza...

# Workflow Engine (Inngest)
INNGEST_SIGNING_KEY=signkey-dev-000000000000
INNGEST_EVENT_KEY=local-dev-key
INNGEST_DEV=1

# Notifications (Novu)
NOVU_API_KEY=your-novu-api-key

# Observability (optional for local dev)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# SENTRY_DSN=https://key@sentry.io/project

# Email (Mailpit via docker-compose for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aptivo.local

# Client-side
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Feature Flags (compile-time, override per deployment)
# FEATURE_WORKFLOW_V2=false
# FEATURE_ADVANCED_SEARCH=true

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# HITL Security
HITL_SECRET=change-me-to-a-32-character-or-longer-secret-for-hitl
