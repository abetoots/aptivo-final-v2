{
  "name": "@aptivo/audit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./middleware": "./src/middleware/index.ts",
    "./async": "./src/async/index.ts",
    "./query": "./src/query/index.ts",
    "./retention": "./src/retention/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aptivo/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aptivo/typescript-config": "workspace:*",
    "@types/node": "^25.3.3",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  }
}
